#!/usr/bin/env bash
if [ -d .venv ]; then
  export VIRTUAL_ENV="$PWD/.venv"
  PATH_add "$VIRTUAL_ENV/bin"
fi

# shellcheck disable=SC1091
source scripts/env/project_config.sh
if py_lib_load_project_env_config "$PWD"; then
  dotenv_if_exists "$PY_LIB_PROJECT_ENV_FILE"
else
  printf '%s\n' "Could not read [tool.py_lib_starter] env config from pyproject.toml." >&2
fi

export PYTHONPATH="$PWD/src:$PWD${PYTHONPATH:+:$PYTHONPATH}"
