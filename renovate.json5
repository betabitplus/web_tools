{
  // Generated repositories track product-owned dependencies directly. Dependencies
  // owned by py-lib-starter are updated in the starter and delivered through
  // template sync PRs.
  extends: ["config:recommended"],
  baseBranchPatterns: ["dev"],
  dependencyDashboard: true,
  semanticCommits: "enabled",
  semanticCommitType: "chore",
  semanticCommitScope: "deps",
  enabledManagers: ["github-actions", "pep621"],
  pep621: {
    managerFilePatterns: ["/^pyproject\\.toml$/"],
  },
  packageRules: [
    {
      description: "Major dependency updates require dashboard approval.",
      matchUpdateTypes: ["major"],
      dependencyDashboardApproval: true,
    },
    {
      description: "Starter-owned Python dependencies are updated by py-lib-starter template syncs.",
      matchManagers: ["pep621"],
      matchPackageNames: [
        "bandit",
        "check-manifest",
        "commitizen",
        "deptry",
        "flake8",
        "flake8-class-attributes-order",
        "flake8-cognitive-complexity",
        "hypothesis",
        "import-linter",
        "interrogate",
        "ipykernel",
        "ipython",
        "nest-asyncio",
        "pillow",
        "pip-audit",
        "pre-commit",
        "py-lib-runtime",
        "py-lib-tooling",
        "pyright",
        "pytest",
        "pytest-cov",
        "pytest-randomly",
        "pytest-recording",
        "pytest-xdist",
        "radon",
        "rich",
        "ruff",
        "setuptools",
        "syrupy",
        "ty",
        "types-pillow",
        "wheel",
      ],
      enabled: false,
    },
    {
      description: 'Starter-owned repository automation is updated by py-lib-starter template syncs. Historical manager set: enabledManagers: ["github-actions", "pep621", "pre-commit"]',
      matchManagers: ["github-actions", "pre-commit"],
      matchFileNames: [
        ".github/actions/**",
        ".github/workflows/build-ci-image.yml",
        ".github/workflows/ci.yml",
        ".github/workflows/release.yml",
        ".github/workflows/sync-starter-template.yml",
        ".pre-commit-config.yaml",
      ],
      enabled: false,
    },
    {
      description: "Product runtime dependencies use release-triggering dependency commits.",
      matchManagers: ["pep621"],
      matchDepTypes: ["project.dependencies"],
      semanticCommitType: "fix",
      semanticCommitScope: "deps",
    },
    {
      description: "Development tooling and repository automation updates are maintenance.",
      matchManagers: ["github-actions", "pre-commit", "pep621"],
      matchDepTypes: ["dependency-groups", "build-system.requires"],
      semanticCommitType: "chore",
      semanticCommitScope: "deps",
    },
  ],
}
